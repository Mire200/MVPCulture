{
  "name": "mvp-culture",
  "version": "0.1.0",
  "private": true,
  "description": "Plateforme de quiz multijoueur party game",
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./apps/**\" dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "dev:web": "pnpm --filter @mvpc/web dev",
    "dev:rt": "pnpm --filter @mvpc/realtime dev",
    "seed": "pnpm --filter @mvpc/db seed",
    "db:migrate": "pnpm --filter @mvpc/db run prisma:migrate",
    "db:push": "pnpm --filter @mvpc/db run prisma:push",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0"
}
