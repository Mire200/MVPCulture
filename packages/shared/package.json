{
  "name": "@mvpc/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./events": {
      "types": "./src/events.ts",
      "import": "./dist/events.js",
      "default": "./dist/events.js"
    },
    "./scoring": {
      "types": "./src/scoring.ts",
      "import": "./dist/scoring.js",
      "default": "./dist/scoring.js"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./modes": {
      "types": "./src/modes.ts",
      "import": "./dist/modes.js",
      "default": "./dist/modes.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
