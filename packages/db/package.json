{
  "name": "@mvpc/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:push": "dotenv -e ../../.env -e .env -- sh -c 'exec prisma db push'",
    "prisma:migrate": "dotenv -e ../../.env -e .env -- sh -c 'exec prisma migrate dev'",
    "postinstall": "prisma generate || true",
    "seed": "dotenv -e ../../.env -e .env -- sh -c 'exec tsx src/seed.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mvpc/shared": "workspace:*",
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx src/seed.ts"
  }
}
